rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: whiteLabelConfigs
    // Document ID: {configId} (typically matches the ownerUid)
    // Fields:
    //   - appName: string (required, < 50 chars)
    //   - primaryColor: string (required, hex format)
    //   - secondaryColor: string (optional, hex format)
    //   - accentColor: string (optional, hex format)
    //   - kaleidoRestUrl: string (optional, URL format)
    //   - kaleidoAuthHeader: string (optional)
    //   - ownerUid: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerUid;
    }

    function uidUnchanged() {
      return !('ownerUid' in request.resource.data) || request.resource.data.ownerUid == request.auth.uid;
    }

    function uidNotModified() {
      return !('ownerUid' in request.resource.data) || request.resource.data.ownerUid == resource.data.ownerUid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidHexColor(color) {
      return color is string && color.matches("^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$");
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidWhiteLabelConfig(data) {
      return hasRequiredFields(['appName', 'primaryColor', 'ownerUid', 'createdAt', 'updatedAt']) &&
             validStringLength('appName', 1, 50) &&
             isValidHexColor(data.primaryColor) &&
             (!( 'secondaryColor' in data ) || isValidHexColor(data.secondaryColor)) &&
             (!( 'accentColor' in data ) || isValidHexColor(data.accentColor)) &&
             (!( 'kaleidoRestUrl' in data ) || isValidUrl(data.kaleidoRestUrl)) &&
             isValidOptionalString('kaleidoAuthHeader', 0, 200) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidIssuedAsset(data) {
      return hasRequiredFields(['name', 'ticker', 'supply', 'type', 'holders', 'status', 'ownerUid', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             validStringLength('ticker', 1, 20) &&
             data.supply is number && data.supply >= 0 &&
             validStringLength('type', 1, 50) &&
             data.holders is number && data.holders >= 0 &&
             validStringLength('status', 1, 50) &&
             data.createdAt is timestamp;
    }

    function isValidRealWorldAsset(data) {
      return hasRequiredFields(['name', 'category', 'valuation', 'fractions', 'oracleStatus', 'ownerUid', 'createdAt']) &&
             validStringLength('name', 1, 150) &&
             validStringLength('category', 1, 50) &&
             data.valuation is number && data.valuation >= 0 &&
             data.fractions is number && data.fractions > 0 &&
             validStringLength('oracleStatus', 1, 50) &&
             data.createdAt is timestamp;
    }

    function isValidNftRevenueModel(data) {
      return hasRequiredFields(['tradingFee', 'creatorRoyalty', 'mintingFee', 'ownerUid', 'updatedAt']) &&
             data.tradingFee is number && data.tradingFee >= 0 &&
             data.creatorRoyalty is number && data.creatorRoyalty >= 0 &&
             data.mintingFee is number && data.mintingFee >= 0 &&
             data.updatedAt is timestamp;
    }

    function isValidNftCollection(data) {
      return hasRequiredFields(['name', 'volume', 'floorPrice', 'change', 'contractAddress', 'ownerUid', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             data.volume is number && data.volume >= 0 &&
             data.floorPrice is number && data.floorPrice >= 0 &&
             data.change is number &&
             validStringLength('contractAddress', 1, 100) &&
             data.createdAt is timestamp;
    }

    function isValidRiskEngineSettings(data) {
      return hasRequiredFields(['maxLeverage', 'maintenanceMargin', 'ownerUid', 'updatedAt']) &&
             data.maxLeverage is number && data.maxLeverage >= 1 && data.maxLeverage <= 100 &&
             data.maintenanceMargin is number && data.maintenanceMargin >= 0 && data.maintenanceMargin <= 100 &&
             data.updatedAt is timestamp;
    }

    function isValidCopiedTrader(data) {
      return hasRequiredFields(['traderId', 'traderName', 'allocation', 'ownerUid', 'createdAt']) &&
             validStringLength('traderId', 1, 100) &&
             validStringLength('traderName', 1, 100) &&
             data.allocation is number && data.allocation > 0 &&
             data.createdAt is timestamp;
    }

    function isValidTokenSale(data) {
      return hasRequiredFields(['name', 'ticker', 'raised', 'target', 'status', 'participants', 'ownerUid', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             validStringLength('ticker', 1, 20) &&
             data.raised is number && data.raised >= 0 &&
             data.target is number && data.target > 0 &&
             data.status in ['Live', 'Upcoming', 'Completed'] &&
             data.participants is number && data.participants >= 0 &&
             data.createdAt is timestamp;
    }

    function isValidMiningPool(data) {
      return hasRequiredFields(['name', 'algo', 'fee', 'status', 'ownerUid', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             validStringLength('algo', 1, 50) &&
             data.fee is number && data.fee >= 0 && data.fee <= 100 &&
             data.status in ['Active', 'Inactive'] &&
             data.createdAt is timestamp;
    }

    function isValidVault(data) {
      return hasRequiredFields(['asset', 'total', 'cold', 'hot', 'status', 'ownerUid', 'createdAt']) &&
             validStringLength('asset', 1, 20) &&
             data.total is number && data.total >= 0 &&
             data.cold is number && data.cold >= 0 &&
             data.hot is number && data.hot >= 0 &&
             data.status in ['Secure', 'Rebalancing'] &&
             data.createdAt is timestamp;
    }

    function isValidPendingTransaction(data) {
      return hasRequiredFields(['txId', 'type', 'amount', 'to', 'sigs', 'requiredSigs', 'ownerUid', 'createdAt']) &&
             validStringLength('txId', 1, 50) &&
             validStringLength('type', 1, 50) &&
             validStringLength('amount', 1, 50) &&
             validStringLength('to', 1, 100) &&
             data.sigs is number && data.sigs >= 0 &&
             data.requiredSigs is number && data.requiredSigs > 0 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /whiteLabelConfigs/{configId} {
      allow read: if true; 

      allow create: if isAuthenticated() && 
                       isOwner(configId) && 
                       isValidWhiteLabelConfig(request.resource.data) && 
                       uidUnchanged();

      allow update: if isAuthenticated() && 
                       isOwner(configId) && 
                       isDocOwner() &&
                       isValidWhiteLabelConfig(request.resource.data) && 
                       uidNotModified() &&
                       request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isAuthenticated() && isOwner(configId) && isDocOwner();
    }

    match /issuedAssets/{assetId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && 
                       isValidIssuedAsset(request.resource.data) && 
                       uidUnchanged();
      allow update: if isAuthenticated() && 
                       isDocOwner() &&
                       isValidIssuedAsset(request.resource.data) && 
                       uidNotModified() &&
                       request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /realWorldAssets/{rwaId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && 
                       isValidRealWorldAsset(request.resource.data) && 
                       uidUnchanged();
      allow update: if isAuthenticated() && 
                       isDocOwner() &&
                       isValidRealWorldAsset(request.resource.data) && 
                       uidNotModified() &&
                       request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /nftRevenueModels/{configId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && isOwner(configId) && isValidNftRevenueModel(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isOwner(configId) && isDocOwner() && isValidNftRevenueModel(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && isOwner(configId) && isDocOwner();
    }

    match /nftCollections/{collectionId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && isValidNftCollection(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidNftCollection(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /riskEngineSettings/{configId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && isOwner(configId) && isValidRiskEngineSettings(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isOwner(configId) && isDocOwner() && isValidRiskEngineSettings(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && isOwner(configId) && isDocOwner();
    }

    match /copiedTraders/{copyId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && isValidCopiedTrader(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidCopiedTrader(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /tokenSales/{saleId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && isValidTokenSale(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidTokenSale(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /miningPools/{poolId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && isValidMiningPool(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidMiningPool(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /vaults/{vaultId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && isValidVault(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidVault(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /pendingTransactions/{txId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && isValidPendingTransaction(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidPendingTransaction(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
